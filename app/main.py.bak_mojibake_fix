                fallback_payload = dict(payload)
                fallback_payload.pop("response_format", None)
                completion = client.chat.completions.create(**fallback_payload)
                return completion.choices[0].message.content
            except Exception:
                pass
        print("API璋冪敤鎶ラ敊:", str(e))
        raise HTTPException(status_code=500, detail="澶фā鍨嬫帴鍙ｅ紓甯?)


def extract_json(text):
    """鎻愬彇骞插噣 JSON"""
    if not text:
        raise ValueError("绌鸿緭鍑?)

    text = text.strip()
    text = re.sub(r"^```(?:json)?\s*", "", text, flags=re.I)
    text = re.sub(r"\s*```$", "", text)

    # 鍏堝皾璇曟暣娈典綔涓?JSON
    try:
        parsed = json.loads(text)
        return json.dumps(parsed, ensure_ascii=False)
    except Exception:
        pass

    # 鍐嶄粠鏂囨湰涓壂鎻忕涓€涓彲琚В鏋愮殑 JSON 瀵硅薄
    decoder = json.JSONDecoder()
    for i, ch in enumerate(text):
        if ch != "{":
            continue
        try:
            obj, _ = decoder.raw_decode(text[i:])
            if isinstance(obj, dict):
                return json.dumps(obj, ensure_ascii=False)
        except Exception:
            continue

    raise ValueError("鏈壘鍒癑SON")


